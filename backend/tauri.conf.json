{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arcane Bridge",
  "version": "0.1.3",
  "identifier": "com.arcanemonitor.bridge",
  "build": {
    "beforeBuildCommand": {
      "script": "npm ci && npm run build",
      "cwd": "../hub"
    },
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "resources": {
      "../hub/dist/arcane-bridge.mjs": "hub/arcane-bridge.mjs"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
