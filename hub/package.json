{
  "name": "arcane-bridge",
  "version": "0.1.4",
  "description": "Central localhost JSONL bridge hub for Arcane apps (Monitor, Guilds, Caster)",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "arcane-bridge": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "build": "node scripts/build-standalone.mjs",
    "build:bundle": "npm run build && node scripts/build-hub-exe.mjs",
    "verify:bundle": "node scripts/verify-hub-bundle.mjs",
    "start:dist": "node dist/arcane-bridge.cjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.0",
    "esbuild": "^0.25.0"
  }
}
